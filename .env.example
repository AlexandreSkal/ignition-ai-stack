# ============================================================
# AI Stack - Ignition + Claude Code
# Copy this file to .env and adjust values as needed
# ============================================================

# ─── Claude Code ───
# No API key needed — authenticates via browser login with Claude Pro.
# Just run "claude" inside the container.

# ─── Ignition ───
IGNITION_PASSWORD=admin
# Ignition REST API key (configure later in Gateway > Config > REST API)
IGNITION_API_KEY=

# ─── PostgreSQL ───
POSTGRES_PASSWORD=ignition_dev_2024

# ─── Git (optional, for Claude Code commits) ───
GIT_AUTHOR_NAME=Your Name
GIT_AUTHOR_EMAIL=your@email.com
